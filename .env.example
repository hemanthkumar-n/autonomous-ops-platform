


# Platform
PLATFORM_NAME=autonomous-ops-platform
ENVIRONMENT=development
WORKFLOW_VERSION=v1

# Prometheus
PROMETHEUS_URL=http://localhost:9090
PROMETHEUS_TIMEOUT=10
PROMETHEUS_RETRIES=3
ENABLE_METRICS_ENRICHMENT=true

# Kubernetes collection
MAX_LOG_LINES=50
ENABLE_POD_LOG_COLLECTION=true
ENABLE_EVENT_COLLECTION=true

# Incident persistence
INCIDENT_HISTORY_DIR=data/incidents
PERSIST_INCIDENTS=true

# AI runtime
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL_NAME=qwen2.5-coder:latest
EMBEDDING_MODEL_NAME=nomic-embed-text
AI_REQUEST_TIMEOUT=180

# Vector memory
VECTORSTORE_PROVIDER=chroma
VECTORSTORE_PATH=data/vectorstore/chroma
VECTORSTORE_COLLECTION_NAME=incident_memory

# Safety
ENABLE_DESTRUCTIVE_REMEDIATION=false
SAFE_MODE=true
